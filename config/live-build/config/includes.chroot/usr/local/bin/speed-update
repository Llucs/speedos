#!/bin/bash
# =============================================================================
# SpeedOS - SpeedUpdate
# Gerenciador de atualizações do sistema (APT) e componentes proprietários (GitHub).
# Deve ser executado com privilégios de root.
# =============================================================================

# Cores para debug
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log() { echo -e "${GREEN}[SpeedUpdate]${NC} $1"; }
warn() { echo -e "${YELLOW}[AVISO]${NC} $1"; }
error() { echo -e "${RED}[ERRO]${NC} $1" >&2; }

# Repositório oficial do SpeedOS (para componentes proprietários)
UPDATE_REPO="https://github.com/Llucs/speedos.git" # Adicionado .git para clonagem
LOCAL_VERSION_FILE="/etc/speedos/version"
TEMP_DIR="/tmp/speedos_update"

# Função para atualizar pacotes do sistema (APT)
update_system() {
    log "Atualizando lista de pacotes do sistema..."
    if ! apt update; then
        error "Falha ao atualizar a lista de pacotes."
        return 1
    fi
    
    log "Atualizando pacotes instalados..."
    if ! apt upgrade -y; then
        error "Falha ao atualizar pacotes."
        return 1
    fi
    
    log "Removendo pacotes desnecessários..."
    apt autoremove -y
    apt clean
    
    log "Atualização do sistema concluída."
    return 0
}

# Função para atualizar componentes proprietários (SpeedCenter, scripts, etc.)
update_proprietary() {
    log "Verificando atualizações de componentes proprietários em $UPDATE_REPO..."
    
    # Instala o git se não estiver presente (necessário para o live-build)
    if ! command -v git &> /dev/null; then
        log "Instalando git para atualização de componentes proprietários..."
        apt install -y git
    fi
    
    mkdir -p "$TEMP_DIR"
    
    # Clonar o repositório (apenas a última versão)
    if ! git clone --depth 1 "$UPDATE_REPO" "$TEMP_DIR"; then
        error "Falha ao clonar o repositório $UPDATE_REPO."
        rm -rf "$TEMP_DIR"
        return 1
    fi
    
    # 2. Substituir arquivos essenciais
    log "Substituindo componentes proprietários..."
    
    # Scripts de otimização (binários)
    cp -f "$TEMP_DIR/config/live-build/config/includes.chroot/usr/local/bin/speed-boost" /usr/local/bin/
    cp -f "$TEMP_DIR/config/live-build/config/includes.chroot/usr/local/bin/speed-clean" /usr/local/bin/
    cp -f "$TEMP_DIR/config/live-build/config/includes.chroot/usr/local/bin/speed-gamer-mode" /usr/local/bin/
    
    # SpeedCenter (e first_boot)
    cp -f "$TEMP_DIR/src/speedos/speedcenter/main.py" /opt/speedos/speedcenter/
    cp -f "$TEMP_DIR/src/speedos/speedcenter/first_boot.py" /opt/speedos/speedcenter/
    
    # Configurações
    cp -f "$TEMP_DIR/config/live-build/config/includes.chroot/etc/speedos/speedos.conf" /etc/speedos/
    
    # 3. Limpeza
    rm -rf "$TEMP_DIR"
    
    log "Atualização de componentes proprietários concluída."
    return 0
}

# --- Execução Principal ---
log "Iniciando SpeedUpdate..."

# 1. Atualiza o sistema base
update_system

# 2. Atualiza os componentes proprietários
update_proprietary

log "SpeedUpdate finalizado."
exit 0
